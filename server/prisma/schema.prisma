// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(uuid())
  title        String
  subtitle     String?
  price        Float
  currency     String   @default("RUB")
  weightLabel  String?  // "60 г", "1 кг"
  badges       String   @default("[]") // JSON string: ["Vegan","Новинка"]
  images       String   @default("[]") // JSON string: ["url1", "url2"]
  collection   String?
  features     String   @default("[]") // JSON string: ["feature1", "feature2"]
  kind         String?
  description  String?
  composition  String?
  storage      String?
  delivery     String?
  inStock      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Order {
  id             String   @id @default(uuid())
  name           String
  phone          String
  address        String?
  comment        String?
  deliveryMethod String   // "самовывоз", "курьер"
  paymentMethod  String?  // "Оплата при получении"
  items          String   // JSON: [{ productId: string, quantity: number, price: number }]
  totalAmount    Float
  status         String   @default("pending")
  createdAt      DateTime @default(now())
}

